{
  "name": "python-run-with-args",
  "displayName": "Python Run With Args",
  "description": "Run Python scripts in VS Code or Cursor with a quick prompt for CLI arguments—remembered per file. Works from the Run menu, Command Palette, and keyboard.",
  "version": "0.0.2",
  "publisher": "kitchelsoftware",
  "repository": {
    "type": "git",
    "url": "https://github.com/luakitch/PyArgsExtension.git"
  },
  "bugs": {
    "url": "https://github.com/luakitch/PyArgsExtension/issues"
  },
  "homepage": "https://github.com/luakitch/PyArgsExtension#readme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "python",
    "arguments",
    "cli",
    "run",
    "argparse",
    "sys.argv",
    "command line",
    "vscode",
    "cursor"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onCommand:pyargs.runWithArgs",
    "onDebugResolve:python",
    "onDebugResolve:debugpy"
  ],
  "main": "./out/extension.js",
  "extensionDependencies": [
    "ms-python.python"
  ],
  "contributes": {
    "commands": [
      {
        "command": "pyargs.runWithArgs",
        "title": "Run Python File with Arguments",
        "category": "Python Args",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "when": "resourceLangId == python && !inDiffEditor",
          "command": "pyargs.runWithArgs",
          "group": "pythonArgs@20"
        }
      ],
      "commandPalette": [
        {
          "command": "pyargs.runWithArgs",
          "when": "editorLangId == python"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pyargs.runWithArgs",
        "key": "ctrl+shift+f5",
        "mac": "cmd+shift+f5",
        "when": "editorLangId == python && editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^3.2.0"
  }
}
